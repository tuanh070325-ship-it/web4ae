NODE_ENV=development
PORT=4000
API_PREFIX=api
FRONTEND_URL=http://localhost:3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=shopanime
DB_CONNECTION_LIMIT=10

DB_SYNC_SCHEMA=true
DB_REBUILD_SCHEMA=false
DB_SEED_ON_START=true

JWT_SECRET=replace-with-64-byte-random-secret
SESSION_SECRET=replace-with-64-byte-random-secret
COOKIE_SECRET=replace-with-64-byte-random-secret
ENCRYPTION_KEY=replace-with-64-byte-random-secret
PASSWORD_PEPPER=replace-with-32-byte-random-secret

N8N_CHATBOT_WEBHOOK_URL=https://n8n.arcanic.ai/webhook/akibacore
N8N_CHATBOT_TIMEOUT_MS=30000
